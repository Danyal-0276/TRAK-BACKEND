DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Extra admin emails (optional). Built-in admins are always:
# danyal@admin.com, shahroz@admin.com, abdullah@admin.com
ADMIN_EMAILS=
# Used by: python manage.py seed_default_admins (or pass --password)
# Example dev default: admin@123
SEED_ADMIN_PASSWORD=
MONGODB_URI=mongodb://127.0.0.1:27017/
MONGODB_RAW_DATABASE=TRAK_DB
CREDIBILITY_MODEL_PATH=
CREDIBILITY_CONFIDENCE_THRESHOLD=0.6
# Optional override in model dir: metadata.json → {"confidence_threshold": 0.55}
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
# Production: DEBUG=False, explicit CORS, HTTPS settings (see README)
# CORS_ALLOW_ALL_ORIGINS=false
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://localhost:5173
# DJANGO_SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
# THROTTLE_REGISTER=10/hour
# THROTTLE_LOGIN=30/hour
# THROTTLE_REFRESH=120/hour
# THROTTLE_PASSWORD_RESET=5/hour
# Password reset email (production: use SMTP or SendGrid backend)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=TRAK <noreply@yourdomain.com>
# Web reset page URL (must match your Vite app)
# PASSWORD_RESET_FRONTEND_URL=https://yourapp.com/reset-password
